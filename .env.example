# 백엔드 API base URL — 환경별로 자동 적용된다(커밋된 mode env 파일):
#   pnpm dev   → .env.development (EC2)
#   pnpm build → .env.production  (EC2)
# 로컬에서 다른 백엔드(localhost:8080 등)를 쓸 때만 아래 주석을 풀어 오버라이드.
# VITE_API_BASE_URL=http://localhost:8080/api

# 앱 표시 이름
VITE_APP_NAME=UNIT:Y 멋쟁이사자처럼 연세대학교 어드민

# mock 데이터 사용 여부. default 는 모드에 따라 다름:
#   dev (pnpm dev)    → 'true'  (.env.local 없어도 mock 으로 동작)
#   prod (pnpm build) → 'false' (mock 계정이 prod 번들에 새는 사고 차단)
# prod 에서 'true' 를 set 하면 vite.config.ts 가 빌드를 막는다.
VITE_USE_MOCK=true

# 백엔드 미가동 단계의 staging/preview 빌드처럼 의도적으로 prod 빌드에서
# mock 을 쓰려면 이 변수를 'true' 로 설정해 가드를 우회한다. 백엔드 연동
# 완료 후엔 이 변수와 VITE_USE_MOCK 모두 제거 → 가드 재활성.
VITE_ALLOW_MOCK_BUILD=

# CS 문의용 오픈카카오 채팅방 URL.
# 값이 비면 플로팅 CS 버튼이 렌더되지 않는다.
# 프로덕션에선 Vercel Project Settings → Environment Variables 에서 주입.
VITE_KAKAO_CS_URL=
